{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ResiliSSH",
  "mainBinaryName": "ResiliSSH",
  "version": "1.0.0",
  "identifier": "com.resiliss.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ResiliSSH",
        "width": 720,
        "height": 665,
        "minWidth": 520,
        "minHeight": 460,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "macOS": {
      "bundleName": "ResiliSSH",
      "infoPlist": "./Info.plist"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
